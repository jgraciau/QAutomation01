# ============================================
# QAutomation01 - Variables de Entorno
# ============================================
# Copia este archivo a .env y configuralo según necesites
# cp .env.example .env

# Base URL para las pruebas
BASE_URL=http://opencart.abstracta.us/index.php?route=

# Entorno (staging, production, local)
ENVIRONMENT=staging

# Modo visual (mostrar navegador)
HEADED=false

# Modo debug (abrir inspector)
DEBUG=false

# Número de workers para ejecución paralela
WORKERS=

# Número de reintentos
RETRIES=0

# Timeout por defecto (en ms)
TIMEOUT=30000

# Reporter tipo (html, json, junit)
REPORTER=html

# Captura de screenshot (on-failure, always, never)
SCREENSHOT=only-on-failure

# Captura de video (on-failure, always, never)
VIDEO=retain-on-failure

# Captura de trace (on-failure, always, never)
TRACE=retain-on-failure
